# =============================================================================
# OLS Agentic Sociology Research Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git. Only .env.example is committed.
# =============================================================================

# --- LLM API Keys ---
# At least one API key required for MVP-A (synthesis model)
OPENAI_API_KEY=sk-placeholder-replace-me
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me
MISTRAL_API_KEY=placeholder-replace-me

# --- Langfuse (Observability) ---
# Get these from Langfuse UI after first login: http://localhost:3000
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_HOST=http://localhost:3000

# --- LiteLLM Proxy (Model Routing) ---
LITELLM_MASTER_KEY=sk-litellm-replace-with-random-string

# --- LanceDB (Vector Store) ---
# Path relative to repo root
LANCEDB_PATH=./data/lancedb

# --- Kestra (Workflow Orchestration) ---
# URL of existing Kestra instance
KESTRA_API_URL=http://localhost:8080

# --- Optional: Local Model Serving ---
# Ollama base URL (if Ollama is running)
OLLAMA_BASE_URL=http://localhost:11434
